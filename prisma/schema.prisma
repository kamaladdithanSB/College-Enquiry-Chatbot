generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TeamRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum MemberStatus {
  ACTIVE
  INVITED
  DISABLED
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  accounts      Account[]
  sessions      Session[]
  teams         TeamMember[]
  verifiedItems Institution[]     @relation("Verifier")
  logs          VerificationLog[] @relation("LogVerifier")
}

model Team {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  members      TeamMember[]
  institutions Institution[]
  logs         VerificationLog[]
}

model TeamMember {
  id        String       @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole     @default(EDITOR)
  status    MemberStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Institution {
  id                  String            @id @default(cuid())
  teamId              String
  name                String
  aliases             String[]          @default([])
  campusCity          String?
  campusCountry       String?
  website             String?
  tuitionUsd          Int
  housingUsd          Int
  miscUsd             Int
  tcoaUsd             Int
  feeSummary          String
  deadlineSummary     String
  applicationDeadline DateTime?
  scholarshipDeadline DateTime?
  sourceLabel         String
  sourceUrl           String
  lastVerifiedAt      DateTime
  verifiedById        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  team                Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  verifiedBy          User?             @relation("Verifier", fields: [verifiedById], references: [id])
  logs                VerificationLog[]

  @@unique([teamId, name])
}

model VerificationLog {
  id                  String      @id @default(cuid())
  teamId              String
  institutionId       String
  verifierId          String?
  note                String?
  sourceUrlSnapshot   String
  lastVerifiedAt      DateTime
  createdAt           DateTime    @default(now())
  team                Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  institution         Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  verifier            User?       @relation("LogVerifier", fields: [verifierId], references: [id])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
